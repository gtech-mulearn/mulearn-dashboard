#!/bin/sh

set -e

echo "🎨 Formatting and linting staged files with Biome..."
# lint-staged runs Biome against staged files only and re-stages what it fixes.
# Do NOT use `git add .` here: it sweeps unrelated work into the commit.
bunx lint-staged

echo "🧠 Running TypeScript type check..."
bun run typecheck

echo "🔐 Scanning for forbidden patterns..."
# Check staged content (excluding .husky) for forbidden patterns
if git diff --cached -- ':!.husky' ':!*.md' | grep -qE 'localStorage\.setItem|sessionStorage\.setItem|console\.log|@ts-ignore|@ts-expect-error'; then
  echo "❌ Forbidden pattern detected in staged changes:"
  git diff --cached -- ':!.husky' ':!*.md' | grep -nE 'localStorage\.setItem|sessionStorage\.setItem|console\.log|@ts-ignore|@ts-expect-error'
  exit 1
fi

echo "✅ Pre-commit checks passed"
