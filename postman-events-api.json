{
  "info": {
    "name": "μLearn Events API",
    "description": "Complete Events system API collection — covers public feeds, event management (CRUD, publish, co-owners, collaborators), admin actions (approve/reject/feature), meta endpoints (organizer options, collaboration targets), and scoped feeds (IG, cluster, campus, company).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "jwt_token", "value": "" },
    { "key": "event_id", "value": "" },
    { "key": "co_owner_id", "value": "" },
    { "key": "collaborator_id", "value": "" },
    { "key": "ig_id", "value": "" },
    { "key": "campus_id", "value": "" },
    { "key": "company_id", "value": "" }
  ],
  "item": [
    {
      "name": "Public",
      "description": "No management authority required. Some need JWT for personalized data.",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/?page=1&event_type=hackathon&cluster=coder&ig=&campus=&company=",
              "host": ["{{base_url}}"],
              "path": ["events", ""],
              "query": [
                { "key": "page", "value": "1", "description": "Page number" },
                {
                  "key": "event_type",
                  "value": "hackathon",
                  "description": "Filter: hackathon | workshop | meetup | conference | bootcamp | competition | other"
                },
                {
                  "key": "cluster",
                  "value": "coder",
                  "description": "Filter by IG cluster: coder | maker | manager | creative"
                },
                {
                  "key": "ig",
                  "value": "",
                  "description": "Filter by Interest Group ID (UUID)"
                },
                {
                  "key": "campus",
                  "value": "",
                  "description": "Filter by Campus org ID (UUID)"
                },
                {
                  "key": "company",
                  "value": "",
                  "description": "Filter by Company org ID (UUID)"
                }
              ]
            },
            "description": "Paginated public event feed. Only shows published/ongoing events."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"hasError\": false,\n  \"response\": {\n    \"data\": [\n      {\n        \"id\": \"uuid\",\n        \"title\": \"Hack the Future 2024\",\n        \"slug\": \"hack-the-future-2024\",\n        \"cover_image\": \"https://...\",\n        \"event_type\": \"hackathon\",\n        \"status\": \"published\",\n        \"start_datetime\": \"2024-06-15T09:00:00Z\",\n        \"end_datetime\": \"2024-06-16T18:00:00Z\",\n        \"is_featured\": true,\n        \"interest_count\": 42,\n        \"venue_type\": \"offline\",\n        \"organiser_type\": \"campus\",\n        \"organiser_name\": \"GEC Thrissur\",\n        \"tags\": [\"hackathon\", \"web3\"]\n      }\n    ],\n    \"pagination\": { \"count\": 150, \"next\": \"?page=2\", \"previous\": null }\n  }\n}"
            }
          ]
        },
        {
          "name": "Featured Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/featured/",
              "host": ["{{base_url}}"],
              "path": ["events", "featured", ""]
            },
            "description": "Homepage slider — latest featured events. No auth required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"hasError\": false,\n  \"response\": [\n    {\n      \"id\": \"uuid\",\n      \"title\": \"Hack the Future 2024\",\n      \"slug\": \"hack-the-future-2024\",\n      \"cover_image\": \"https://...\",\n      \"event_type\": \"hackathon\",\n      \"status\": \"published\",\n      \"start_datetime\": \"2024-06-15T09:00:00Z\",\n      \"end_datetime\": \"2024-06-16T18:00:00Z\",\n      \"is_featured\": true,\n      \"interest_count\": 42,\n      \"venue_type\": \"offline\",\n      \"organiser_type\": \"campus\",\n      \"organiser_name\": \"GEC Thrissur\",\n      \"tags\": [\"hackathon\"]\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Event Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}/",
              "host": ["{{base_url}}"],
              "path": ["events", "{{event_id}}", ""]
            },
            "description": "Full event detail. Optional JWT — if provided, includes viewer_interest."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"hasError\": false,\n  \"response\": {\n    \"id\": \"uuid\",\n    \"title\": \"Hack the Future 2024\",\n    \"slug\": \"hack-the-future-2024\",\n    \"description\": \"A 24-hour hackathon...\",\n    \"cover_image\": \"https://...\",\n    \"banner_image\": \"https://...\",\n    \"event_type\": \"hackathon\",\n    \"status\": \"published\",\n    \"start_datetime\": \"2024-06-15T09:00:00Z\",\n    \"end_datetime\": \"2024-06-16T18:00:00Z\",\n    \"registration_url\": \"https://forms.gle/...\",\n    \"registration_deadline\": \"2024-06-14T23:59:00Z\",\n    \"min_karma\": 100,\n    \"is_collaboration\": false,\n    \"is_featured\": true,\n    \"interest_count\": 42,\n    \"venue\": {\n      \"venue_type\": \"offline\",\n      \"address\": \"Main Auditorium\",\n      \"city\": \"Thrissur\",\n      \"maps_url\": \"https://maps.google.com/...\",\n      \"online_link\": null,\n      \"platform\": null\n    },\n    \"scope\": {\n      \"scope\": \"campus\",\n      \"target_org_id\": \"uuid\",\n      \"target_ig_id\": null,\n      \"target_ci_org_id\": null,\n      \"target_ci_ig_id\": null,\n      \"target_org_name\": \"GEC Thrissur\",\n      \"target_ig_name\": null\n    },\n    \"organiser\": {\n      \"organiser_type\": \"campus\",\n      \"ig_id\": null,\n      \"org_id\": \"uuid\",\n      \"ci_org_id\": null,\n      \"ci_ig_id\": null,\n      \"ig_name\": null,\n      \"org_name\": \"GEC Thrissur\",\n      \"ci_org_name\": null,\n      \"ci_ig_name\": null\n    },\n    \"tags\": [\"hackathon\", \"web3\"],\n    \"collaborators\": [],\n    \"co_owners\": [],\n    \"edit_history\": [],\n    \"created_by\": \"uuid\",\n    \"created_by_name\": \"John Doe\",\n    \"created_at\": \"2024-06-01T10:00:00Z\",\n    \"updated_at\": \"2024-06-10T14:30:00Z\",\n    \"viewer_interest\": \"going\"\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"statusCode\": 400,\n  \"hasError\": true,\n  \"message\": { \"general\": [\"Event not found\"] }\n}"
            }
          ]
        },
        {
          "name": "Mark Interest (I'm Going)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}/interest/",
              "host": ["{{base_url}}"],
              "path": ["events", "{{event_id}}", "interest", ""]
            },
            "description": "Toggle \"I'm Going\" on an event. Requires JWT."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"hasError\": false,\n  \"message\": { \"general\": [\"Interest registered\"] }\n}"
            },
            {
              "name": "400 Already interested",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"statusCode\": 400,\n  \"hasError\": true,\n  \"message\": { \"general\": [\"Already marked as interested\"] }\n}"
            }
          ]
        },
        {
          "name": "Remove Interest",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/{{event_id}}/interest/",
              "host": ["{{base_url}}"],
              "path": ["events", "{{event_id}}", "interest", ""]
            },
            "description": "Remove \"I'm Going\" from an event. Requires JWT."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"hasError\": false,\n  \"message\": { \"general\": [\"Interest removed\"] }\n}"
            }
          ]
        }
      ]
    },
    {
