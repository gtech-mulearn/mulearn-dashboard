              "raw": "{\n  \"title\": \"Hack the Future 2024\",\n  \"description\": \"A 24-hour hackathon focused on building innovative solutions.\",\n  \"cover_image\": \"https://example.com/cover.jpg\",\n  \"banner_image\": \"https://example.com/banner.jpg\",\n  \"event_type\": \"hackathon\",\n  \"start_datetime\": \"2024-06-15T09:00:00Z\",\n  \"end_datetime\": \"2024-06-16T18:00:00Z\",\n  \"registration_url\": \"https://forms.gle/example\",\n  \"registration_deadline\": \"2024-06-14T23:59:00Z\",\n  \"min_karma\": 100,\n  \"venue\": {\n    \"venue_type\": \"offline\",\n    \"address\": \"Main Auditorium, GEC Thrissur\",\n    \"city\": \"Thrissur\",\n    \"maps_url\": \"https://maps.google.com/...\",\n    \"online_link\": null,\n    \"platform\": null\n  },\n  \"scope\": {\n    \"scope\": \"campus\",\n    \"target_org_id\": \"campus-uuid\",\n    \"target_ig_id\": null,\n    \"target_ci_org_id\": null,\n    \"target_ci_ig_id\": null\n  },\n  \"organiser\": {\n    \"organiser_type\": \"campus\",\n    \"ig_id\": null,\n    \"org_id\": \"campus-uuid\",\n    \"ci_org_id\": null,\n    \"ci_ig_id\": null\n  },\n  \"tags\": [\"hackathon\", \"web3\", \"innovation\"]\n}"
